* ======================================================================
* 2kb SRAM Pre-Simulation: Write and Read Operations Validation (Compact)
* Fixed: MUX tracking issue via removal of dummy load, restoring Ans functionality
* ======================================================================

.PROTECT
.INCLUDE '/RAID2/COURSE/2026_Spring/es26mcs/es26mcs068/7nm_TT.pm'
.UNPROTECT

.OPTION POST=1 FSDB 
.OPTION RUNLVL=6
.OPTION METHOD=GEAR
.OPTION CAPTAB=1

.PARAM SUP = 0.7V
.GLOBAL VDD GND
VVDD VDD GND 'SUP'

* ======================================================================
* 1. 基礎邏輯與核心元件 (包含強健的 Buffer Tree)
* ======================================================================
* 最小 Buffer
.SUBCKT INV_MIN IN OUT
Mp OUT IN VDD VDD pmos_rvt nfin=2
Mn OUT IN GND GND nmos_rvt nfin=1
.ENDS
.SUBCKT BUF_MIN IN OUT
X1 IN N1 INV_MIN
X2 N1 OUT INV_MIN
.ENDS

* 驅動級 Buffer
.SUBCKT INV_X4 IN OUT
Mp OUT IN VDD VDD pmos_rvt nfin=8
Mn OUT IN GND GND nmos_rvt nfin=4
.ENDS
.SUBCKT BUF_X4 IN OUT
X1 IN N1 INV_X4
X2 N1 OUT INV_X4
.ENDS
.SUBCKT BUF_X16 IN OUT
X1 IN N1 BUF_X4
X2 N1 OUT BUF_X4
.ENDS
.SUBCKT BUF_X64 IN OUT
X1 IN N1 BUF_X16
X2 N1 OUT BUF_X16
.ENDS

* ======================================================================
* 2. Ans 子電路 (SRAM_CELL, MUX, SENSE_AMP, WRITE_DRIVER)
* ======================================================================
.subckt SRAM_CELL WL BL BLB VSS VDD
M_pl  q   qb  VDD VDD pmos_sram L=2e-08 W=2.7e-08 NFIN=1
M_nl  q   qb  VSS VSS nmos_sram L=2e-08 W=2.7e-08 NFIN=2
M_pr  qb  q   VDD VDD pmos_sram L=2e-08 W=2.7e-08 NFIN=1
M_nr  qb  q   VSS VSS nmos_sram L=2e-08 W=2.7e-08 NFIN=2
M_pgl BL  WL  q   VSS nmos_sram L=2e-08 W=2.7e-08 NFIN=2
M_pgr BLB WL  qb  VSS nmos_sram L=2e-08 W=2.7e-08 NFIN=2
.ends

.subckt PRECHARGE_UNIT PRE BL BLB VDD
M_pr1 BL  PRE VDD VDD pmos_sram L=2e-08 W=2.7e-08 NFIN=2
M_pr2 BLB PRE VDD VDD pmos_sram L=2e-08 W=2.7e-08 NFIN=2
M_pr3 BL  PRE BLB VDD pmos_sram L=2e-08 W=2.7e-08 NFIN=2
.ends

.subckt COL_MUX_2TO1 BL_in0 BLB_in0 BL_in1 BLB_in1 BL_out BLB_out sel0 sel1 VSS
M_mux0 BL_out  sel0 BL_in0  VSS nmos_sram L=2e-08 W=2.7e-08 NFIN=4
M_mux1 BLB_out sel0 BLB_in0 VSS nmos_sram L=2e-08 W=2.7e-08 NFIN=4
M_mux2 BL_out  sel1 BL_in1  VSS nmos_sram L=2e-08 W=2.7e-08 NFIN=4
M_mux3 BLB_out sel1 BLB_in1 VSS nmos_sram L=2e-08 W=2.7e-08 NFIN=4
.ends

.subckt SENSE_AMP_LATCH BL BLB sense sense_b SA_EN VDD VSS
M_pr_s1 sense   SA_EN VDD VDD pmos_sram L=2e-08 W=2.7e-08 NFIN=4
M_pr_s2 sense_b SA_EN VDD VDD pmos_sram L=2e-08 W=2.7e-08 NFIN=4
M_pr_eq sense   SA_EN sense_b VDD pmos_sram L=2e-08 W=2.7e-08 NFIN=4
M_pr_d1 di      SA_EN VDD VDD pmos_sram L=2e-08 W=2.7e-08 NFIN=4
M_pr_d2 dib     SA_EN VDD VDD pmos_sram L=2e-08 W=2.7e-08 NFIN=4
M_sa1 sense   sense_b VDD VDD pmos_sram L=2e-08 W=2.7e-08 NFIN=4
M_sa2 sense_b sense   VDD VDD pmos_sram L=2e-08 W=2.7e-08 NFIN=4
M_sa3 sense   sense_b di  VSS nmos_sram L=2e-08 W=2.7e-08 NFIN=4
M_sa4 sense_b sense   dib VSS nmos_sram L=2e-08 W=2.7e-08 NFIN=4
M_in1 di  BLB tail VSS nmos_sram L=2e-08 W=2.7e-08 NFIN=4
M_in2 dib BL  tail VSS nmos_sram L=2e-08 W=2.7e-08 NFIN=4
M_tail tail SA_EN VSS VSS nmos_sram L=2e-08 W=2.7e-08 NFIN=4
.ends

.subckt WRITE_DRIVER D D_bar WR_EN BL_out BLB_out VDD VSS
M_n1 BL_out WR_EN   D VSS nmos_sram L=2e-08 W=2.7e-08 NFIN=4
M_p1 BL_out WR_EN_b D VDD pmos_sram L=2e-08 W=2.7e-08 NFIN=4
M_n2 BLB_out WR_EN   D_bar VSS nmos_sram L=2e-08 W=2.7e-08 NFIN=4
M_p2 BLB_out WR_EN_b D_bar VDD pmos_sram L=2e-08 W=2.7e-08 NFIN=4
M_invp WR_EN_b WR_EN VDD VDD pmos_sram L=2e-08 W=2.7e-08 NFIN=2
M_invn WR_EN_b WR_EN VSS VSS nmos_sram L=2e-08 W=2.7e-08 NFIN=1
.ends

.subckt NAND2 A B Y VDD VSS
Mp1 Y A VDD VDD pmos_sram L=2e-08 W=2.7e-08 NFIN=2
Mp2 Y B VDD VDD pmos_sram L=2e-08 W=2.7e-08 NFIN=2
Mn1 Y A n1  VSS nmos_sram L=2e-08 W=2.7e-08 NFIN=2
Mn2 n1 B VSS VSS nmos_sram L=2e-08 W=2.7e-08 NFIN=2
.ends

.subckt INV_S in out VDD VSS
M_p out in VDD VDD pmos_sram L=2e-08 W=2.7e-08 NFIN=1
M_n out in VSS VSS nmos_sram L=2e-08 W=2.7e-08 NFIN=1
.ends
.subckt INV_M in out VDD VSS
M_p out in VDD VDD pmos_sram L=2e-08 W=2.7e-08 NFIN=2
M_n out in VSS VSS nmos_sram L=2e-08 W=2.7e-08 NFIN=2
.ends
.subckt INV_L in out VDD VSS
M_p out in VDD VDD pmos_sram L=2e-08 W=2.7e-08 NFIN=4
M_n out in VSS VSS nmos_sram L=2e-08 W=2.7e-08 NFIN=4
.ends

* ======================================================================
* 3. 架構封裝 (Compact ROW / COL_PERIPHERAL / GLOBAL_CTRL)
* ======================================================================

* 周邊控制邏輯：負責 Precharge, Mux, WD, SA
.SUBCKT COL_PERIPHERAL SEL0 SEL1 D_IN WEN CLK SAEN PRE BL0 BLB0 BL1 BLB1 Q_OUT
X_pre0 PRE BL0 BLB0 VDD PRECHARGE_UNIT
X_pre1 PRE BL1 BLB1 VDD PRECHARGE_UNIT
X_mux BL0 BLB0 BL1 BLB1 BL_CH BLB_CH SEL0 SEL1 GND COL_MUX_2TO1
X_wd_inv D_IN D_IN_B VDD GND INV_L
X_wd D_IN D_IN_B WEN BL_CH BLB_CH VDD GND WRITE_DRIVER
X_sa BL_CH BLB_CH sense sense_b SAEN VDD GND SENSE_AMP_LATCH
X_out_buf sense_b Q_OUT VDD GND INV_M
.ENDS

* 頂層核心時脈與讀寫控制
.SUBCKT GLOBAL_CTRL CLK WEN PRE WR_EN SAEN
X_pre_buf1 CLK clk_b VDD GND INV_S
X_pre_buf2 clk_b PRE VDD GND INV_L
X_wen_inv WEN WEN_b VDD GND INV_S
X_wr_nand CLK WEN_b WR_EN_nand VDD GND NAND2
X_wr_buf  WR_EN_nand WR_EN VDD GND INV_L
X_d1 CLK clk_d1 VDD GND INV_S
X_d2 clk_d1 clk_d2 VDD GND INV_S
X_d3 clk_d2 clk_d3 VDD GND INV_S
X_d4 clk_d3 clk_d4 VDD GND INV_S
X_d5 clk_d4 clk_d5 VDD GND INV_S
X_d6 clk_d5 clk_d6 VDD GND INV_S
X_d7 clk_d6 clk_d7 VDD GND INV_S
X_d8 clk_d7 clk_d8 VDD GND INV_S
X_d9 clk_d8 clk_d9 VDD GND INV_S
X_d10 clk_d9 clk_d10 VDD GND INV_S
X_d11 clk_d10 clk_d11 VDD GND INV_S
X_d12 clk_d11 clk_d12 VDD GND INV_S
X_d13 clk_d12 clk_d13 VDD GND INV_S
X_d14 clk_d13 clk_d14 VDD GND INV_S
X_d15 clk_d14 clk_d15 VDD GND INV_S
X_d16 clk_d15 clk_d16 VDD GND INV_S
X_d17 clk_d16 clk_d17 VDD GND INV_S
X_d18 clk_d17 clk_d18 VDD GND INV_S
X_d19 clk_d18 clk_d19 VDD GND INV_S
X_d20 clk_d19 clk_d20 VDD GND INV_S
X_d21 clk_d20 clk_d21 VDD GND INV_S
X_d22 clk_d21 clk_d22 VDD GND INV_S
X_d23 clk_d22 clk_d23 VDD GND INV_S
X_d24 clk_d23 clk_d24 VDD GND INV_S
X_d25 clk_d24 clk_d25 VDD GND INV_S
X_d26 clk_d25 clk_d26 VDD GND INV_S
X_d27 clk_d26 clk_d27 VDD GND INV_S
X_d28 clk_d27 clk_d28 VDD GND INV_S
X_d29 clk_d28 clk_d29 VDD GND INV_S
X_d30 clk_d29 clk_d30 VDD GND INV_S
X_d31 clk_d30 clk_d31 VDD GND INV_S
X_d32 clk_d31 clk_delayed VDD GND INV_S
X_sa_nand clk_delayed WEN SA_EN_nand VDD GND NAND2
X_sa_buf  SA_EN_nand SA_EN VDD GND INV_L
.ENDS

* ======================================================================
* 4. 系統核心整合 (Top Level Pre-Sim Structure)
* ======================================================================
X_CTRL CLK WEN PRE WR_EN SAEN GLOBAL_CTRL

X_a0_inv A0 A0_b VDD GND INV_S
X_sel0_buf A0 A0_sel0 VDD GND INV_L
X_sel1_buf A0_b A0_sel1 VDD GND INV_L

* 引入全新的 3 組 2-to-4 Decoder
.INCLUDE 'decoder_6to64_3x2to4.sp'

* 實體化 6-to-64 Row Decoder
X_ROW_DEC CLK A6 A5 A4 A3 A2 A1 WL0 WL1 WL2 WL3 WL4 WL5 WL6 WL7 WL8 WL9 WL10 WL11 WL12 WL13 WL14 WL15 WL16 WL17 WL18 WL19 WL20 WL21 WL22 WL23 WL24 WL25 WL26 WL27 WL28 WL29 WL30 WL31 WL32 WL33 WL34 WL35 WL36 WL37 WL38 WL39 WL40 WL41 WL42 WL43 WL44 WL45 WL46 WL47 WL48 WL49 WL50 WL51 WL52 WL53 WL54 WL55 WL56 WL57 WL58 WL59 WL60 WL61 WL62 WL63 VDD GND ROW_DECODER_3X2TO4

